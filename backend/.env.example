# PostgreSQL
DB_URL=jdbc:postgresql://localhost:5432/docmind
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_SECRET=change-this-to-a-long-random-secret-at-least-256-bits
JWT_EXPIRATION_MS=86400000

# Astra DB
ASTRA_TOKEN=your-astra-db-token
ASTRA_DATABASE_ID=your-database-id
ASTRA_REGION=us-east-2
ASTRA_KEYSPACE=pdf
ASTRA_TABLE=pdfchat
ASTRA_DIMENSION=384

# Ollama Cloud
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=your-ollama-api-key
OLLAMA_MODEL=gpt-oss:20b

# Web Search (optional) - pick ONE provider, leave the other key blank
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPER_API_KEY=
WEB_SEARCH_MAX_RESULTS=5

# Application
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:5173
